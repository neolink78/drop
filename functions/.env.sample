# Database (SQLite - a single file relative to the functions/ dir)
DATABASE_URL="file:./prod.db"

# Server
PORT="4000"
# Lock CORS to your public site in production (e.g. https://drop.thibautresse.ovh)
CORS_ORIGIN="http://localhost:3000"

# Stripe
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
STRIPE_PUBLIC_KEY="pk_test_your_stripe_public_key"

# AliExpress Open Platform (Dropshipping API)
# Create a "Drop Shipping" app at https://console.aliexpress.com to get these.
ALIEXPRESS_APP_KEY="your_app_key"
ALIEXPRESS_APP_SECRET="your_app_secret"
# Must match the callback URL registered on the AliExpress console.
ALIEXPRESS_CALLBACK_URL="http://localhost:4000/api/admin/aliexpress/callback"
# Optional gateway override (defaults to the Singapore endpoint).
# ALIEXPRESS_GATEWAY_URL="https://api-sg.aliexpress.com/sync"

# Defaults used when fetching product data
DEFAULT_SHIP_COUNTRY="FR"
DEFAULT_CURRENCY="EUR"
DEFAULT_LANGUAGE="FR"

# Authentication
JWT_SECRET="your_jwt_secret_key_change_this_in_production"
ADMIN_EMAIL="admin@example.com"

# Business Logic
MARKUP_PERCENTAGE="50"

# Frontend URL
FRONTEND_URL="http://localhost:3000"

# Store branding
STORE_NAME="Nuvo"
SUPPORT_EMAIL="contact@shopnuvo.fr"

# Transactional email (SMTP - e.g. Brevo). If unset, emails are skipped.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Nuvo <contact@shopnuvo.fr>"